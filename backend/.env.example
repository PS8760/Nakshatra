# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/
DB_NAME=cogniscan

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string in production: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=72

# ── Groq (free — get key at console.groq.com) ────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# Requires Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM=your_email@gmail.com
TEAM_EMAIL=your_email@gmail.com

# ── CORS (production) ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://cogniscan-ai.vercel.app,https://www.cogniscanai.com
ALLOWED_ORIGINS=https://your-app.vercel.app
